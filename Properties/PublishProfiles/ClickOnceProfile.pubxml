<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
ClickOnce publish profile for NovaSFTP2. Used by the GitHub Actions workflow
(.github/workflows/clickonce.yml) and reproducible locally via:
  msbuild NovaSFTP2.csproj /t:Publish /p:PublishProfile=ClickOnceProfile /p:Configuration=Release
-->
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>ClickOnce</PublishProtocol>
    <PublishDir>bin\publish\</PublishDir>
    <PublishUrl>bin\publish\</PublishUrl>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- Framework-dependent keeps the package small; the .NET 10 Desktop Runtime
         is offered to the end user via the bootstrapper prerequisite below.
         Flip SelfContained to True for a no-prerequisites (but much larger) build. -->
    <SelfContained>false</SelfContained>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishSingleFile>false</PublishSingleFile>

    <!-- ClickOnce install / update behaviour -->
    <Install>true</Install>
    <UpdateEnabled>true</UpdateEnabled>
    <UpdateMode>Foreground</UpdateMode>
    <UpdateRequired>false</UpdateRequired>
    <MapFileExtensions>true</MapFileExtensions>
    <CreateDesktopShortcut>true</CreateDesktopShortcut>

    <!-- Versioning: ApplicationVersion is overridden by the workflow so each run
         produces an incrementing version. The trailing 0 is the revision. -->
    <ApplicationVersion>2.0.0.0</ApplicationVersion>
    <ApplicationRevision>0</ApplicationRevision>
    <MinimumRequiredVersion>2.0.0.0</MinimumRequiredVersion>

    <!-- Branding / web page -->
    <ProductName>NovaSFTP2</ProductName>
    <PublisherName>Mitch Capper</PublisherName>
    <CreateWebPageOnPublish>true</CreateWebPageOnPublish>
    <WebPage>https://github.com/mitchcapper/NovaSFTP2</WebPage>
    <OpenBrowserOnPublish>false</OpenBrowserOnPublish>

    <!-- Manifests are generated but not Authenticode-signed (no cert in CI). -->
    <GenerateManifests>true</GenerateManifests>
    <SignManifests>false</SignManifests>

    <!-- Prerequisite bootstrapper: offer to install the .NET Desktop Runtime. -->
    <BootstrapperEnabled>true</BootstrapperEnabled>
  </PropertyGroup>
  <ItemGroup>
    <BootstrapperPackage Include="Microsoft.NetCore.DesktopRuntime.10.0.x64">
      <Visible>False</Visible>
      <ProductName>.NET Desktop Runtime 10.0 (x64)</ProductName>
      <Install>true</Install>
    </BootstrapperPackage>
  </ItemGroup>
</Project>
