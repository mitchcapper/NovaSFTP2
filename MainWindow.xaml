<Window x:Class="NovaSFTP2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
		xmlns:local="clr-namespace:NovaSFTP2"
        Icon="/icon1.png"
		xmlns:ThemeToggle="clr-namespace:WPFNativeThemeToggleControl;assembly=WPFNativeThemeToggleControl"
		ResizeMode="NoResize"
        Title="{Binding title}" Height="450" Width="525" DataContext="{Binding Main, Source={StaticResource Locator}}"  >

	<Window.TaskbarItemInfo>
		<TaskbarItemInfo />
	</Window.TaskbarItemInfo>

	<Grid Margin="5">
		<Grid.Resources>
			<!--<Style TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
				<Setter Property="FontWeight" Value="Bold"/>
				<Setter Property="HorizontalAlignment" Value="Right"/>
				<Setter Property="VerticalAlignment" Value="Center"/>
			</Style>
			<Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
				<Setter Property="VerticalAlignment" Value="Center"/>
				<Setter Property="Margin" Value="10,0"/>
			</Style>

			<Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
				<Setter Property="VerticalAlignment" Value="Center"/>
				<Setter Property="HorizontalAlignment" Value="Center"/>
				<Setter Property="Padding" Value="6"/>

			</Style>-->

		</Grid.Resources>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="150" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Label Content="Connector Type:"/>
		<ThemeToggle:ThemeToggleControl HorizontalAlignment="Left" CurrentThemeStr="{Binding current_theme, Mode=TwoWay}" />
		<StackPanel Grid.Column="1" VerticalAlignment="Center"  HorizontalAlignment="Left"  Orientation="Horizontal">
			<ComboBox  IsEnabled="{Binding type_selector_enabled}" ItemsSource="{Binding UPLOAD_TYPES}" SelectedItem="{Binding upload_type}" Width="100"/>
			<CheckBox Visibility="{Binding show_docker_options}" Content="Compression" IsChecked="{Binding use_compression, Mode=TwoWay}" VerticalAlignment="Center"  />
			<Label Visibility="{Binding show_docker_options}" Content=" TLS:"/>
			<ComboBox Visibility="{Binding show_docker_options}" ItemsSource="{Binding TLS_MODES}" SelectedItem="{Binding tls_mode}" Width="110" />
		</StackPanel>
		<Label Content="Host:" Grid.Row="1" />
		<Grid Grid.Row="1" Grid.Column="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="60" />
			</Grid.ColumnDefinitions>
			<TextBox Text="{Binding hostname}" ToolTip="Hostname" />
			<TextBox Text="{Binding port}" ToolTip="Port" Grid.Column="1"/>
		</Grid>

		<Label Content="{Binding UsernameLabel}" Grid.Row="2" />
		<ui:AutoSuggestBox x:Name="txtUser" VerticalAlignment="Center" Margin="2" Text="{Binding username,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" TextChanged="FileCRTPathBox_OnTextChanged" SuggestionChosen="PathBox_OnSuggestionChosen" QuerySubmitted="PathBox_OnQuerySubmitted" Grid.Row="2" Grid.Column="1" Visibility="{Binding show_docker_options}" />
		<TextBox Text="{Binding username}" Grid.Row="2" Grid.Column="1"  Visibility="{Binding show_sftp_options}" />
		<Label Content="{Binding PasswordLabel}" Grid.Row="3" />
		<ui:AutoSuggestBox x:Name="txtPassword" VerticalAlignment="Center" Margin="2" Text="{Binding password,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" TextChanged="FilePFXPathBox_OnTextChanged" SuggestionChosen="PathBox_OnSuggestionChosen" QuerySubmitted="PathBox_OnQuerySubmitted"  Grid.Row="3" Grid.Column="1"  Visibility="{Binding show_docker_options}" />
		<PasswordBox  Grid.Row="3" Grid.Column="1"  VerticalAlignment="Center" local:PasswordBoxHelper.BindPassword="True" 
         local:PasswordBoxHelper.BoundPassword="{Binding password, Mode=TwoWay}" Margin="2" ui:ControlHelper.PlaceholderText="Password (leave blank for paegent public key)"
					  Visibility="{Binding show_sftp_options}" />

		<Label Content="Container:" Grid.Row="4"  Visibility="{Binding show_docker_options}" />
		<TextBox Text="{Binding container}" Grid.Row="4" Grid.Column="1" Visibility="{Binding show_docker_options}" />

		<Grid Grid.Row="5" Grid.ColumnSpan="2" >
			<Grid.RowDefinitions>
				<RowDefinition />
				<RowDefinition />
				<RowDefinition />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<Label Content="Local Folder:" Grid.Row="0" />
			<ui:AutoSuggestBox x:Name="txtPath"  Margin="2" Text="{Binding local_folder, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"  TextChanged="FilePathBox_OnTextChanged" SuggestionChosen="PathBox_OnSuggestionChosen" QuerySubmitted="PathBox_OnQuerySubmitted" />
			<!--		<TextBox Text="{Binding local_folder}" Grid.Row="3" Grid.Column="1" />-->
			<Label Content="Monitor Sub Folders:" Grid.Row="1" />
			<StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
				<CheckBox IsChecked="{Binding include_subfolders}" Width="25" MinWidth="25"   VerticalAlignment="Center" Margin="5,0,0,0"/>
				<!--<Label FontSize="10" Content="Ignore when TS and size same:" />-->
				<CheckBox IsChecked="{Binding ignore_ts_size_same}" Margin="20,0,10,0" FontSize="10" Content="Ignore when TS &amp; size same"  VerticalAlignment="Center"/>

				<CheckBox IsChecked="{Binding cache_existing_ts}" Margin="10,0,0,0" FontSize="10" Content="Pre-cache existing" IsEnabled="{Binding ignore_ts_size_same}"  VerticalAlignment="Center"/>
			</StackPanel>

			<Label Content="Remote Base Folder:" Grid.Row="2" />
			<TextBox Text="{Binding remote_folder}" Grid.Row="2" Grid.Column="1" />
		</Grid>
		<StackPanel Orientation="Horizontal" Grid.Row="6" HorizontalAlignment="Left" Grid.ColumnSpan="2">
			<ComboBox IsEnabled="{Binding type_selector_enabled}" StaysOpenOnEdit="True" IsEditable="True" ItemsSource="{Binding hosts}" SelectedItem="{Binding selected_host, Mode=TwoWay}" Width="225" VerticalAlignment="Center" />
			<Button Content="Delete"  Command="{Binding FavDelCmd, Mode=OneWay}" />
			<Button Content="Save"  Command="{Binding FavSaveCmd, Mode=OneWay}" />
			<Button Content="Save As" Command="{Binding FavSaveAsCmd, Mode=OneWay}" />
		</StackPanel>
		<Button Content="{Binding action_button_content}" Command="{Binding  ToggleConnectedCmd, Mode=OneWay}" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left"  />


		<Label Content="Ignore RegEx Pattern:" Grid.Row="8" />
		<TextBox Text="{Binding ignore_regex,Mode=TwoWay}" Grid.Row="8" Grid.Column="1" />

	</Grid>
</Window>
